modules = ["nodejs-20"]

run = "node index.mjs"
entrypoint = "index.mjs"

[agent]
expertMode = true
integrations = ["javascript_anthropic_ai_integrations:2.0.0", "javascript_openai_ai_integrations:2.0.0"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["node", "index.mjs"]
deploymentTarget = "autoscale"

[[ports]]
localPort = 3000
externalPort = 80
